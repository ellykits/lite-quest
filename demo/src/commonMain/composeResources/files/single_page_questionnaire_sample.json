{
  "id": "household-registration",
  "title": "Household & Head Registration",
  "version": "1.0.0",
  "items": [
    {
      "linkId": "welcomeBox",
      "type": "LAYOUT_BOX",
      "items": [
        {
          "linkId": "introText",
          "text": "Welcome to the Community Health Registration. Please ensure all details are accurate for the Household Head and members.",
          "type": "DISPLAY"
        }
      ]
    },
    {
      "linkId": "consentGiven",
      "text": "Do you consent to the registration?",
      "type": "BOOLEAN",
      "required": true
    },
    {
      "linkId": "householdId",
      "text": "Scan Household Card",
      "type": "BARCODE",
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      }
    },
    {
      "linkId": "structureDetails",
      "text": "Building Characteristics",
      "type": "TEXT",
      "required": true,
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      }
    },
    {
      "linkId": "roomsCount",
      "text": "Number of Sleeping Rooms",
      "type": "INTEGER",
      "required": true,
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      }
    },
    {
      "linkId": "waterUsage",
      "text": "Monthly Water Usage",
      "type": "QUANTITY",
      "required": true,
      "extension": {
        "unit": "L"
      },
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      }
    },
    {
      "linkId": "nameRow",
      "type": "LAYOUT_ROW",
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      },
      "items": [
        {
          "linkId": "firstName",
          "text": "First Name",
          "type": "STRING",
          "required": true
        },
        {
          "linkId": "lastName",
          "text": "Last Name",
          "type": "STRING",
          "required": true
        },
        {
          "linkId": "fullNameDisplay",
          "text": "Full Name (Calculated)",
          "type": "STRING",
          "readOnly": true,
          "calculatedExpression": {
            "cat": [
              {
                "var": "firstName"
              },
              " ",
              {
                "var": "lastName"
              }
            ]
          }
        }
      ]
    },
    {
      "linkId": "demographicsRow",
      "type": "LAYOUT_ROW",
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      },
      "items": [
        {
          "linkId": "dob",
          "text": "Date of Birth",
          "type": "DATE",
          "required": true,
          "extension": {
            "displayFormat": "dd/MM/yyyy",
            "outputFormat": "yyyy-MM-dd"
          }
        },
        {
          "linkId": "gender",
          "text": "Gender",
          "type": "CHOICE",
          "required": true,
          "answerOptions": [
            {
              "code": "m",
              "display": "Male"
            },
            {
              "code": "f",
              "display": "Female"
            },
            {
              "code": "o",
              "display": "Other"
            }
          ]
        },
        {
          "linkId": "otherGender",
          "text": "Other Gender",
          "type": "STRING",
          "required": true,
          "visibleIf": {
            "==": [
              {
                "var": "gender"
              },
              "o"
            ]
          }
        }
      ]
    },
    {
      "linkId": "occupation",
      "text": "Primary Occupation",
      "type": "OPEN_CHOICE",
      "required": true,
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      },
      "answerOptions": [
        {
          "code": "farmer",
          "display": "Farmer"
        },
        {
          "code": "trader",
          "display": "Trader"
        },
        {
          "code": "teacher",
          "display": "Teacher"
        },
        {
          "code": "none",
          "display": "None of the above",
          "exclusive": true
        }
      ]
    },
    {
      "linkId": "vitalsCol",
      "type": "LAYOUT_COLUMN",
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      },
      "items": [
        {
          "linkId": "height",
          "text": "Height (m)",
          "type": "DECIMAL",
          "required": true
        },
        {
          "linkId": "weight",
          "text": "Weight (kg)",
          "type": "DECIMAL",
          "required": true
        },
        {
          "linkId": "bmiDisplay",
          "text": "Calculated BMI",
          "type": "DECIMAL",
          "readOnly": true,
          "calculatedExpression": {
            "/": [
              {
                "var": "weight"
              },
              {
                "*": [
                  {
                    "var": "height"
                  },
                  {
                    "var": "height"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    {
      "linkId": "visitLog",
      "type": "LAYOUT_ROW",
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      },
      "items": [
        {
          "linkId": "visitTime",
          "text": "Registration Timestamp",
          "type": "DATETIME",
          "required": true,
          "extension": {
            "displayFormat": "dd/MM/yyyy HH:mm",
            "outputFormat": "yyyy-MM-dd'T'HH:mm:ss'Z'"
          }
        },
        {
          "linkId": "followUpTime",
          "text": "Preferred Follow-up",
          "type": "TIME",
          "required": true,
          "extension": {
            "use24Hour": true
          }
        }
      ]
    },
    {
      "linkId": "headPhoto",
      "text": "Head of Household Photo",
      "type": "IMAGE",
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      }
    },
    {
      "linkId": "idDocument",
      "text": "National ID Scan (Attachment)",
      "type": "ATTACHMENT",
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      }
    },
    {
      "linkId": "membersSection",
      "text": "Household Members",
      "type": "GROUP",
      "repeats": true,
      "visibleIf": {
        "==": [
          {
            "var": "consentGiven"
          },
          true
        ]
      },
      "items": [
        {
          "linkId": "memberName",
          "text": "Member Name",
          "type": "STRING",
          "required": true
        },
        {
          "linkId": "relationship",
          "text": "Relationship to Head",
          "type": "CHOICE",
          "required": true,
          "answerOptions": [
            {
              "code": "spouse",
              "display": "Spouse"
            },
            {
              "code": "child",
              "display": "Child"
            },
            {
              "code": "other",
              "display": "Relative"
            }
          ]
        }
      ]
    },
    {
      "linkId": "ratingSection",
      "text": "App Experience",
      "type": "GROUP",
      "items": [
        {
          "linkId": "appRating",
          "text": "How would you rate your experience with this form?",
          "type": "RATING",
          "required": true
        }
      ]
    }
  ]
}
